                                                            navigator.userAgentData || {},
                                                        checkbox_offer_aid: "",
                                                    },
                                                }),
                                                referrer:
                                                    "https://www.fool.com/ext-content/5-pullback-stocks-that-are-on-sale-now-3/",
                                                referrerPolicy: "no-referrer-when-downgrade",
